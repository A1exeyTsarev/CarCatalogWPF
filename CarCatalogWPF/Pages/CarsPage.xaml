<Page x:Class="CarCatalogWPF.Pages.CarsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CarCatalogWPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Каталог автомобилей"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== ВЕРХНЯЯ ПАНЕЛЬ (Фильтры и поиск) ===== -->
        <Border Grid.Row="0" Background="#F0F4F8" CornerRadius="10" Margin="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" 
                        HorizontalAlignment="Center" Margin="10">

                <!-- Фильтр по стране -->
                <StackPanel Orientation="Vertical" Margin="10,0">
                    <TextBlock Text="Страна:" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboFilter" Width="150" Height="30"
                              SelectionChanged="ComboFilter_SelectionChanged"/>
                </StackPanel>

                <!-- Сортировка -->
                <StackPanel Orientation="Vertical" Margin="10,0">
                    <TextBlock Text="Сортировка:" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboSort" Width="180" Height="30"
                              SelectionChanged="ComboSort_SelectionChanged"/>
                </StackPanel>

                <!-- Поиск -->
                <StackPanel Orientation="Vertical" Margin="10,0">
                    <TextBlock Text="Поиск:" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="TextSearch" Width="200" Height="30"
                             TextChanged="TextSearch_TextChanged"/>
                </StackPanel>

                <!-- Кнопка Добавить -->
                <Button x:Name="BtnAdd" Content="➕ Добавить" 
                        Click="BtnAdd_Click" 
                        Height="30" Width="100" Margin="20,20,0,0"
                        Visibility="Collapsed"
                        Background="#2ECC71" Foreground="White"
                        FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- ===== СПИСОК АВТОМОБИЛЕЙ ===== -->
        <ListView Grid.Row="1" x:Name="LvCars" Margin="10" 
                  MouseDoubleClick="LvCars_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" 
                            Margin="5" Padding="10" CornerRadius="8"
                            Background="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- КАРТИНКА -->
                            <Border Margin="3" ClipToBounds="True" Grid.Column="0">
                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill" 
                                       Width="130" Height="90"/>
                            </Border>

                            <!-- ИНФОРМАЦИЯ -->
                            <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left" Margin="15,0">
                                <TextBlock Text="{Binding BrandName}" FontWeight="Bold" FontSize="18"/>

                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,5,0,5">
                                    <Run Text="Страна: "/><Run Text="{Binding CountryName}"/>
                                </TextBlock>

                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,5,0,5">
                                    <Run Text="Год выпуска: "/><Run Text="{Binding Year}"/>
                                </TextBlock>

                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,5,0,5">
                                    <Run Text="Цена: "/><Run Text="{Binding Price}"/><Run Text=" руб."/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ===== НИЖНЯЯ ПАНЕЛЬ (Счетчик + Кнопки) ===== -->
        <Border Grid.Row="2" Background="#F0F4F8" CornerRadius="10" Margin="10">
            <Grid>
                <TextBlock x:Name="TbCounter" Text="🚗 Всего автомобилей: 0" 
                           VerticalAlignment="Center" HorizontalAlignment="Left" 
                           Margin="20,0,0,0" FontWeight="SemiBold"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" 
                            HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button x:Name="BtnEdit" Content="✏️ Редактировать" 
                            Click="BtnEdit_Click" 
                            Height="30" Width="120" Margin="0,0,10,0"
                            Background="#3498DB" Foreground="White"
                            FontWeight="Bold"/>
                    <Button x:Name="BtnDelete" Content="🗑️ Удалить" 
                            Click="BtnDelete_Click" 
                            Height="30" Width="120" Margin="0,0,10,0"
                            Background="#E74C3C" Foreground="White"
                            FontWeight="Bold"/>
                    <Button Content="🚪 Выход" 
                            Click="BtnExit_Click" 
                            Height="30" Width="120"
                            Background="#95A5A6" Foreground="White"
                            FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>