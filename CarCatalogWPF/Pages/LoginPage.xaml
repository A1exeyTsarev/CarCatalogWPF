<Page x:Class="CarCatalogWPF.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CarCatalogWPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid Background="White">
        <Image HorizontalAlignment="Left" Height="100" Margin="-98,6,0,0" VerticalAlignment="Top" Width="100"/>
        <TextBlock HorizontalAlignment="Left" Margin="305,28,0,0" TextWrapping="Wrap" Text="Вход" VerticalAlignment="Top" Height="56" Width="160" FontSize="24" FontWeight="Bold" TextAlignment="Center" RenderTransformOrigin="0.222,0.429"/>
        <TextBox x:Name="TbLogin" HorizontalAlignment="Left" Margin="282,131,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="150" Height="42" TextChanged="TextBox_TextChanged" FontSize="18"/>
        <Button x:Name="BtnLogin" Content="Войти" HorizontalAlignment="Left" Margin="227,282,0,0" VerticalAlignment="Top" Height="50" Width="130" FontSize="20" Click="BtnLogin_Click"/>
        <Button x:Name="BtnRegister" Content="Регистрация" HorizontalAlignment="Left" Margin="425,282,0,0" VerticalAlignment="Top" Height="50" Width="130" FontSize="20" Click="BtnRegister_Click"/>
        <PasswordBox x:Name="PbPassword" HorizontalAlignment="Left" Margin="282,208,0,0" VerticalAlignment="Top" Width="150" Height="42"/>
        <TextBlock HorizontalAlignment="Left" Margin="282,91,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="35" Width="100" FontSize="24" FontWeight="Bold" TextAlignment="Center" RenderTransformOrigin="0.222,0.429"><Run Language="ru-ru" Text="Логин"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="282,168,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="35" Width="100" FontSize="24" FontWeight="Bold" TextAlignment="Center" RenderTransformOrigin="0.222,0.429"><Run Language="ru-ru" Text="Пароль"/></TextBlock>


    </Grid>
</Page>
